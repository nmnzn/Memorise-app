.<div class="container p-4">

    <div class="d-flex justify-content-between align-items-start p-3">
        <%= link_to "<", memo_card_path(@card), class:"btn btn-secondary me-3" %>
        <h1 class="text-end text-headings-font-family">Modifier une card :</h1>
    </div>

  <%= simple_form_for [@memo, @card], html: { class: "simple-form" } do |f| %>
    <%= f.input :ask, label: "Question : #{@card.ask}", placeholder: "Saisir la nouvelle question" %>
    <div class="mb-4 text-secondary">Question actuelle : <%= @card.ask %></div>
    <%= f.input :answer, label: "Réponse :", placeholder: "Saisir la nouvelle réponse" %>
    <div class="mb-4 text-secondary">Réponse actuelle : <%= @card.answer %></div>
    <div class="mt-3 text-end"><%= f.button :submit, "Enregistrer", class:"btn btn-success" %></div>
    
  <% end %>
</div>
