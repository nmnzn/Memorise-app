<div class="container p-4">

  <div class="d-flex justify-content-between align-items-start p-3">
    <%= link_to memos_path, class: "memo-item__arrow text-decoration-none" do %>
      <i class="fa-solid fa-arrow-left"></i>
    <% end %>
    <h3 class="mb-4 text-font-family-sans-serif text-end">Cette card appartient au mémo:</h3>
  </div>

  <div class="d-flex justify-content-between">
    <h1 class="mb-4 text-headings-font-family"><%= @card.memo.name %></h1>
    <span class="img-very-small"><%= image_tag "mascotte_love", alt: "mascotte avec des yeux en coeurs tout mignon" %></span>
  </div>

  <h2 class="text-primary text-headings-font-family">Question : </h2>
  <div class="memo-card mb-4">
    <p><%= @card.ask %></p>
  </div>

  <h2 class="text-primary text-headings-font-family">Réponse : </h2>
  <div class="memo-card">
    <p><%= @card.answer %></p>
  </div>

  <% if @memo.user == current_user %>
    <div class="d-flex justify-content-around mt-5">
      <%= link_to "Editer", edit_memo_card_path(@memo, @card), class: "btn btn-warning btn-sm" %>
      <%= link_to "Supprimer", memo_card_path(@memo, @card), class: "btn btn-danger btn-sm", data: { turbo_method: :delete, turbo_confirm: "Etes vous sûr(e) de vouloir supprimer cette card ?" } %>
    </div>
  <% end %>

</div>
