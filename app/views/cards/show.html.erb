<h1><%= @memo.name %></h1>

<div class="card p-4 mt-4">
  <h2>Question</h2>
  <p><%= @card.ask %></p>

  <details class="mt-3">
    <summary class="btn btn-outline-primary">Voir la réponse</summary>
    <div class="mt-3">
      <h3>Réponse</h3>
      <p><%= @card.answer %></p>
    </div>
  </details>
</div>

<div class="mt-4">
  <%= link_to "Retour au mémo", memo_path(@memo), class: "btn btn-secondary" %>
</div>
