<% if @chat.title_previously_changed? %>
  <%= turbo_stream.update "chat_title", @chat.title %>
<% end %>

<%= turbo_stream.append "messages" do %>
  <%= render "messages/messages", messages: @chat.messages.last(2) %>
<% end %>

<%= turbo_stream.update "new_message_container" do %>
  <%= render "messages/form", chat: @chat, message: Message.new %>
<% end %>

<%= turbo_stream.update "chat_messages" do %>
  <%= render "chats/shared/chat", messages: @messages %>
<% end %>

<%= turbo_stream.update "message_form" do %>
  <%= render "chats/shared/message_input", chat: @chat, message: Message.new %>
<% end %>
