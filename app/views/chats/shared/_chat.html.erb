
<div class="rounded-5 overflow-scroll mb-2" style="height: 30vh" data-controller="auto-scroll-bottom">
    <% if messages.empty? %>
      <p>Que souhaitez vous mémoriser ?</p>
      <p>Laisse-toi guider pour générer ton programme de mémorisation.</p>
    <% else %>
            <% messages.each do |message| %>
                <% if message.role == "user" %>
                    <div class="d-flex justify-content-end mb-2">
                        <div class="bg-success ms-5 p-2 rounded-pill text-white shadow-sm"><%= message.content %></div>
                    </div>
                <% elsif message.role == "assistant" %>
                    <div class="d-flex justify-content-start mb-2">
                        <div class="bg-primary me-5 p-2 rounded-pill text-white shadow-sm"><%= message.content %></div>
                    </div>
                <% end %>
            <% end %>
    <% end %>
</div>
