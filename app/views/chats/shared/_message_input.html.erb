<%= turbo_frame_tag "message_form" do %>
  <%= simple_form_for [chat, message], html: { class: "simple-form-generate", data: { controller: "chat-submit", action: "submit->chat-submit#loading" } } do |f| %>
    <div class="chat-input-row">
      <%= f.text_area :content, placeholder: "Parle nous du sujet que tu souhaites mémoriser", autocomplete: "off", data: { controller: "auto-resize", action: "input->auto-resize#resize", gramm: "false", gramm_editor: "false" } %>
      <button type="submit" class="btn chat-send-btn text-center" data-chat-submit-target="button" data-action="mousedown->chat-submit#preventBlur">
        <span data-chat-submit-target="icon"><i class="fa-solid fa-arrow-right fa"></i></span>
        <span data-chat-submit-target="spinner" class="d-none">
          <span class="spinner-border spinner-border-sm" role="status"></span>
        </span>
      </button>
    </div>
  <% end %>
<% end %>
