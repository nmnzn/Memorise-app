  <div class="memo-new-form mt-6">
    <div class="auth-card">
      <h2 class="auth-title">Connexion</h2>
      <p class="auth-sub">Content de te revoir !</p>

      <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-inputs">
        <%= f.input :email,
                    required: false,
                    autofocus: true,
                    input_html: { autocomplete: "email", class: "auth-input" } %>
        <%= f.input :password,
                    required: false,
                    input_html: { autocomplete: "current-password", class: "auth-input" } %>
        <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
      </div>

      <div class="form-actions justify-items-center">
        <%= f.button :submit, "Se connecter", class: "btn btn-primary" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
