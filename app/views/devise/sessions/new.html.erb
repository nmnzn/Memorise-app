<div class="auth-page">
  <div class="page-title sticker-text">
    <h1>Connexion</h1>
  </div>

    <div class="text-center">
    <p>Content de te revoir !</p>
    </div>

  <div class="auth-card vh-80">
    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-inputs">
        <%= f.input :email,
                    required: false,
                    autofocus: true,
                    input_html: { autocomplete: "email", class: "auth-input" } %>
        <%= f.input :password,
                    required: false,
                    input_html: { autocomplete: "current-password", class: "auth-input" } %>
        <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
      </div>

      <div class="form-actions justify-items-center">
        <%= f.button :submit, "Se connecter", class: "btn btn-primary btn-shadow" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
