<%- if controller_name != 'sessions' %>
  <p><%= link_to "Se connecter", new_session_path(resource_name), class: "btn btn-primary btn-shadow" %></p>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <p><%= link_to "Créer un compte", new_registration_path(resource_name), class: "btn btn-secondary btn-shadow" %></p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p><%= link_to "Mot de passe oublié?", new_password_path(resource_name), class: "btn btn-secondary btn-shadow" %></p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p><%= link_to "Je n'ai pas reçu les instructions de confirmation", new_confirmation_path(resource_name), class: "btn btn-link btn-shadow" %></p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <p><%= link_to "Je n'ai pas reçu les instructions de déverrouillage", new_unlock_path(resource_name), class: "btn btn-link btn-shadow" %></p>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <p><%= button_to "S'authentifier avec #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false } %></p>
  <% end %>
<% end %>
