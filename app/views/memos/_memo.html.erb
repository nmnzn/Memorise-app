<div class="memo-item"
    data-controller="navigate"
    data-navigate-url-value="<%= memo_path(memo) %>"
    data-action="click->navigate#go">

  <div class="memo-item__info">
    <span class="memo-item__name"><%= memo.name %></span>
    <span class="memo-item__badge"><%= Answer.where(card: memo.cards, user: current_user, value: true).count %> / <%= memo.cards.count %></span>
  </div>

  <div class="memo-item__actions">
    <% if memo.user == current_user %>
      <%= link_to memo_path(memo, anchor: "memo-share-section"),
          class: "memo-item__share",
          title: "Partager ce mémo",
          onclick: "event.stopPropagation();" do %>
        <i class="fa-solid fa-share"></i>
      <% end %>
    <% end %>

    <%= button_to memo_path(memo),
        method: :delete,
        form: { data: { turbo_confirm: "Supprimer ce mémo ?" } },
        class: "memo-item__trash",
        onclick: "event.stopPropagation();" do %>
      <i class="fa-solid fa-trash"></i>
    <% end %>
  </div>
</div>
