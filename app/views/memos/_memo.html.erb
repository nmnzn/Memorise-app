<div class="memo-item"
    data-controller="navigate"
    data-navigate-url-value="<%= memo_path(memo) %>"
    data-action="click->navigate#go">

  <div class="memo-item__info">
    <span class="memo-item__name"><%= memo.name %></span>

    <div class="memo-item__meta">
      <span class="memo-item__badge">
        <%= Answer.where(card: memo.cards, user: current_user, value: true).count %> / <%= memo.cards.count %>
      </span>

      <span class="memo-item__visibility <%= memo.is_public? ? 'memo-item__visibility--public' : 'memo-item__visibility--private' %>">
        <%= memo.visibility_label %>
      </span>
    </div>
  </div>

  <div class="memo-item__actions">
    <% if memo.user == current_user %>
      <%= button_to toggle_visibility_memo_path(memo),
          method: :patch,
          class: "memo-item__visibility-btn",
          title: (memo.is_public? ? "Rendre privé" : "Rendre public"),
          onclick: "event.stopPropagation();" do %>
        <% if memo.is_public? %>
          <i class="fa-solid fa-lock-open"></i>
        <% else %>
          <i class="fa-solid fa-lock"></i>
        <% end %>
      <% end %>

      <%= link_to memo_path(memo, anchor: "memo-share-section"),
          class: "memo-item__share",
          title: "Partager ce mémo",
          onclick: "event.stopPropagation();" do %>
        <i class="fa-solid fa-share"></i>
      <% end %>
    <% end %>

    <%= button_to memo_path(memo),
        method: :delete,
        form: { data: { turbo_confirm: "Supprimer ce mémo ?" } },
        class: "memo-item__trash",
        onclick: "event.stopPropagation();" do %>
      <i class="fa-solid fa-trash"></i>
    <% end %>
  </div>
</div>
