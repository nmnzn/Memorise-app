<div>

  <div class="memos-header">
    <h1>Mes mémos</h1>
  </div>
  <div class="text-center mb-4 mt-8">
  <%= link_to "Nouveau Mémo", new_memo_path, class: " btn btn-lg btn-primary btn-shadow" %>
  </div>

  <div class="memos-page">
    <% if @memos.any? %>
      <div class="memos-list">
        <% @memos.each do |memo| %>
            <div class="memo-item">
            <div class="memo-item__info">
              <span class="memo-item__name"><%= memo.name %></span>
              <span class="memo-item__badge">0 / <%= memo.cards.count %></span>
            </div>
            <%= link_to memo_path(memo), class: "memo-item__arrow text-decoration-none" do %>
              <i class="fa-solid fa-arrow-right"></i>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-center mt-4">Aucun mémo pour le moment.</p>
    <% end %>
  </div>
</div>
