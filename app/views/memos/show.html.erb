<h1><%= @memo.name %></h1>
<%= link_to "Retour", memos_path, class:"btn btn-secondary" %>
<%= link_to "Créer une card", new_memo_card_path(@memo), class:"btn btn-success" %>
<%= link_to "Editer le mémo", edit_memo_path(@memo), class:"btn btn-warning" %>

<ul>
  <% @cards.each do |card| %>
    <li><%= link_to card.ask, memo_card_path(@memo, card) %></li>
  <% end %>
</ul>
