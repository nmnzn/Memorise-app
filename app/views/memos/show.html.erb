<h1><%= @memo.name %></h1>
<%= link_to "Retour", memos_path, class:"btn btn-secondary" %>
<%= link_to "Créer une card", new_memo_card_path(@memo), class:"btn btn-success" %>
<%= link_to "Editer le mémo", edit_memo_path(@memo), class:"btn btn-warning" %>

<p>Sujet initial : <%= @memo.prompt %></p>

<ul>
  <% @cards.each do |card| %>
    <li><%= link_to card.ask, memo_card_path(@memo, card) %></li>
  <% end %>
</ul>

<%= link_to "Supprimer", memo_path(@memo), data: { turbo_method: :delete, turbo_confirm: "Etes vous sûr(e) de vouloir supprimer ce mémo ?" } %>

<h1><%= @memo.name %></h1>
<p><%= @memo.prompt %></p>

<% @cards.each do |card| %>
  <div class="card">
    <p><strong>Question :</strong> <%= card.question %></p>
    <p><strong>Réponse :</strong> <%= card.answer %></p>
  </div>
<% end %>
