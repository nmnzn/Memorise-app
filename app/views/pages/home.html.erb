<% if user_signed_in? %>
  <div class="dashboard-home">
    <p class="text-center">
      Bienvenue <%= current_user.email.split("@").first.capitalize %> ! <br>Que souhaites-tu <strong style="color: #F59E0B">mémoriser</strong> aujourd’hui ?
    </p>

    <div class="dashboard-home__actions">
      <%= link_to "Mes mémos", memos_path, class: "btn btn-primary btn-shadow" %>
      <%= link_to "Créer un mémo", new_memo_path, class: "btn btn-secondary btn-shadow" %>
    </div>

    <div class="dashboard-home__stats">
      <div class="dashboard-home__circle">
        <svg viewBox="0 0 120 120">
          <circle class="dashboard-home__circle-bg" cx="60" cy="60" r="52"></circle>
          <circle
            class="dashboard-home__circle-value"
            cx="60"
            cy="60"
            r="52"
            stroke-dasharray="<%= 2 * Math::PI * 52 %>"
            stroke-dashoffset="<%= 2 * Math::PI * 52 * (1 - (@progress_percent.to_f / 100)) %>">
          </circle>
        </svg>
        <span><%= @progress_percent %>%</span>
      </div>

      <div class="dashboard-home__stats-text">
        <h3>De flashcards déjà mémorisées</h3>
        <p><%= @known_cards_count %> sur <%= @total_cards_count %> cards maîtrisées</p>
      </div>
    </div>

    <h2 class="dashboard-home__subtitle">Tes mémos favoris</h2>

    <% if @favorite_memos.any? %>
      <div class="dashboard-home__list">
        <%= render @favorite_memos %>
      </div>
    <% else %>
      <p class="dashboard-home__empty">Tu n’as pas encore de mémo favori.</p>
    <% end %>
  </div>
<% else %>
  <div class="home-page">

    <div class="home-hero">
      <p class="home-hero__tag">Flashcards • Révision • Mémorisation</p>
      <h1 class="home-hero__title">Transforme tes <span>révisions</span> en réflexes.</h1>
      <p class="home-hero__sub">Organise tes sujets, crée tes flashcards et révise avec une interface claire et motivante.</p>

      <div class="home-hero__actions">
        <%= link_to "Commencer", new_user_registration_path, class: "btn btn-primary btn-shadow" %>
        <%= link_to "Se connecter", new_user_session_path, class: "btn btn-secondary btn-shadow" %>
      </div>
    </div>

    <div class="home-features">
      <div class="home-feature">
        <span class="home-feature__num">01</span>
        <h3 class="home-feature__title">Organise</h3>
        <p class="home-feature__text">Crée des mémos par sujet pour structurer ton apprentissage.</p>
      </div>
      <div class="home-feature">
        <span class="home-feature__num">02</span>
        <h3 class="home-feature__title">Apprends</h3>
        <p class="home-feature__text">Ajoute des flashcards pour transformer tes notes en entraînement actif.</p>
      </div>
      <div class="home-feature">
        <span class="home-feature__num">03</span>
        <h3 class="home-feature__title">Retiens</h3>
        <p class="home-feature__text">Révise plus souvent, plus vite, et garde l'essentiel en mémoire.</p>
      </div>
    </div>

  </div>
<% end %>
