<div class="play-card">
  <div class="play-question"><%= card.ask %></div>

  <div class="play-answer-btn-wrap" data-play-target="revealBtn">
    <button type="button" class="play-answer-btn" data-action="play#toggleAnswer">
      Voir la réponse
    </button>
  </div>

  <div class="play-answer hidden" data-play-target="answer"><%= card.answer %></div>

  <div class="play-knowledge-actions hidden" data-play-target="actions">
    <%= button_to "Je savais",        knew_play_path(card),         method: :patch, class: "play-knowledge-btn play-knowledge-btn--success" %>
    <%= button_to "Je ne savais pas", did_not_know_play_path(card), method: :patch, class: "play-knowledge-btn play-knowledge-btn--danger" %>
  </div>
</div>
