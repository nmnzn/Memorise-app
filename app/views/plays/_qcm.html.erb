<div class="play-card">
  <div class="play-question"><%= card.ask %></div>

  <div class="play-qcm-choices">
    <% card.qcm_choices.each do |choice| %>
      <button type="button"
              class="play-qcm-btn"
              data-action="play#selectChoice"
              data-choice="<%= choice %>">
        <%= choice %>
      </button>
    <% end %>
  </div>

  <%= button_to "✓", knew_play_path(card),         method: :patch, class: "hidden", data: { play_target: "knewBtn" } %>
  <%= button_to "✗", did_not_know_play_path(card), method: :patch, class: "hidden", data: { play_target: "nopeBtn" } %>
</div>
