<div class="play-page">
  <div class="play-topbar">
    <%= link_to "←", memos_path, class: "play-back" %>
  </div>

  <div class="play-card">
    <h2>Question de la card</h2>

    <div class="play-question">
      <%= @card.ask %>
    </div>

    <div class="play-answer-btn-wrap">
      <button type="button" class="play-answer-btn" onclick="toggleAnswer()">
        Voir la réponse
      </button>
    </div>

    <div id="play-answer" class="play-answer hidden">
      <%= @card.answer %>
    </div>

    <div id="play-knowledge-actions" class="play-knowledge-actions hidden">
      <%= button_to "Je savais", knew_play_path(@card), method: :patch, class: "play-knowledge-btn play-knowledge-btn--success" %>
      <%= button_to "Je ne savais pas", did_not_know_play_path(@card), method: :patch, class: "play-knowledge-btn play-knowledge-btn--danger" %>
    </div>
  </div>
</div>

<script>
  function toggleAnswer() {
    const answer = document.getElementById("play-answer");
    const actions = document.getElementById("play-knowledge-actions");

    answer.classList.remove("hidden");
    actions.classList.remove("hidden");
  }
</script>
