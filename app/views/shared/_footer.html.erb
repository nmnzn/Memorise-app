<footer class="bg-dark border-top border-secondary py-5 mt-5">
  <div class="container">
    <div class="row gy-4">
      <div class="col-md-5">
        <div class="d-flex align-items-center gap-2 mb-2">
          <span class="badge bg-primary text-dark">M</span>
          <h5 class="text-light fw-bold mb-0">Memorise App</h5>
        </div>
        <p class="text-secondary">Organise tes sujets, crée tes flashcards et retiens l'essentiel plus facilement.</p>
      </div>

      <div class="col-md-2 offset-md-1">
        <h6 class="text-light fw-bold mb-3">Navigation</h6>
        <ul class="list-unstyled">
          <li class="mb-2"><%= link_to "Accueil", root_path, class: "text-secondary text-decoration-none" %></li>
          <li class="mb-2"><%= link_to "Mes sujets", memos_path, class: "text-secondary text-decoration-none" %></li>
          <li><%= link_to "Créer un sujet", new_memo_path, class: "text-secondary text-decoration-none" %></li>
        </ul>
      </div>

      <div class="col-md-2">
        <h6 class="text-light fw-bold mb-3">Compte</h6>
        <ul class="list-unstyled">
          <% if user_signed_in? %>
            <li><%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-secondary text-decoration-none" %></li>
          <% else %>
            <li class="mb-2"><%= link_to "Connexion", new_user_session_path, class: "text-secondary text-decoration-none" %></li>
            <li><%= link_to "Inscription", new_user_registration_path, class: "text-secondary text-decoration-none" %></li>
          <% end %>
        </ul>
      </div>

      <div class="col-md-2">
        <h6 class="text-light fw-bold mb-3">Produit</h6>
        <ul class="list-unstyled text-secondary">
          <li class="mb-2">Flashcards</li>
          <li class="mb-2">Mémorisation</li>
          <li>Révision par sujets</li>
        </ul>
      </div>
    </div>

    <hr class="border-secondary mt-4">
    <p class="text-secondary mb-0 small">© <%= Time.current.year %> Memorise App. Tous droits réservés.</p>
  </div>
</footer>
