<footer class="memorise-footer">
  <div class="container">
    <div class="memorise-footer-content">
      <div class="memorise-footer-brand">
        <div class="memorise-footer-logo">
          <span>M</span>
        </div>
        <div>
          <h3>Memorise App</h3>
          <p>Organise tes sujets, crée tes flashcards et retiens l’essentiel plus facilement.</p>
        </div>
      </div>

      <div class="memorise-footer-links">
        <div class="memorise-footer-column">
          <h4>Navigation</h4>
          <%= link_to "Accueil", root_path %>
          <%= link_to "Mes sujets", memos_path %>
          <%= link_to "Créer un sujet", new_memo_path %>
        </div>

        <div class="memorise-footer-column">
          <h4>Compte</h4>
          <% if user_signed_in? %>
            <%= link_to "Déconnexion",
                destroy_user_session_path,
                data: { turbo_method: :delete } %>
          <% else %>
            <%= link_to "Connexion", new_user_session_path %>
            <%= link_to "Inscription", new_user_registration_path %>
          <% end %>
        </div>

        <div class="memorise-footer-column">
          <h4>Produit</h4>
          <p>Flashcards</p>
          <p>Mémorisation</p>
          <p>Révision par sujets</p>
        </div>
      </div>
    </div>

    <div class="memorise-footer-bottom">
      <p>© <%= Time.current.year %> Memorise App. Tous droits réservés.</p>
    </div>
  </div>
</footer>
